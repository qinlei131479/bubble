# 编译产物与依赖（最大噪音源）
**/target/
**/node_modules/
**/dist/
**/build/
**/.out/
**/.next/
**/coverage/
**/__pycache__/
**/*.egg-info/

# 环境与敏感文件
.env
.env.local
.env.*.local
*.pem

# 大型 / 二进制文件
*.csv
*.jsonl
*.parquet
*.mp4
*.mp3
*.wav
*.jpg
*.jpeg
*.png
*.gif
*.ico
*.woff
*.woff2
*.ttf
*.eot

# IDE 与系统
**/.idea/
**/.vscode/
**/.DS_Store
Thumbs.db

# Python 虚拟环境
**/.venv/
**/venv/
**/.tox/

# Docker 挂载数据
docker/volume/
docker/.data/

# 日志
**/logs/
*.log

# 自动生成文件（不应手动编辑）
**/git.properties
apps/bubble-ui/auto-imports.d.ts
apps/bubble-ui/components.d.ts
.flattened-pom.xml

# 数据库初始化 SQL（大文件，按需读取）
script/db/*.sql
