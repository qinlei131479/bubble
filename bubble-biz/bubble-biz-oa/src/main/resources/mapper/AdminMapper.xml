<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bubblecloud.biz.oa.mapper.AdminMapper">

	<resultMap id="adminMap" type="com.bubblecloud.oa.api.entity.Admin">
		<id property="id" column="id" />
		<result property="uid" column="uid" />
		<result property="account" column="account" />
		<result property="password" column="password" />
		<result property="avatar" column="avatar" />
		<result property="name" column="name" />
		<result property="phone" column="phone" />
		<result property="job" column="job" />
		<result property="isAdmin" column="is_admin" />
		<result property="roles" column="roles" />
		<result property="uniOnline" column="uni_online" />
		<result property="clientId" column="client_id" />
		<result property="scanKey" column="scan_key" />
		<result property="lastIp" column="last_ip" />
		<result property="loginCount" column="login_count" />
		<result property="status" column="status" />
		<result property="isInit" column="is_init" />
		<result property="language" column="language" />
		<result property="mark" column="mark" />
		<result property="createdAt" column="created_at" />
		<result property="updatedAt" column="updated_at" />
		<result property="deletedAt" column="deleted_at" />
	</resultMap>

	<select id="findPg" resultType="com.bubblecloud.oa.api.entity.Admin">
		SELECT t.*
		FROM eb_admin t
		WHERE t.deleted_at IS NULL
	</select>

	<select id="selectEntUserList" resultType="com.bubblecloud.oa.api.vo.company.CompanyUserListItemVO">
		SELECT a.id,
		       a.name,
		       a.avatar,
		       a.phone,
		       a.job,
		       MAX(j.name) AS jobName,
		       GROUP_CONCAT(DISTINCT f.name ORDER BY f.id SEPARATOR ',') AS frameNames
		FROM eb_admin a
		INNER JOIN eb_frame_assist fa ON fa.user_id = a.id
			AND fa.entid = #{entid}
			AND fa.deleted_at IS NULL
		LEFT JOIN eb_frame f ON f.id = fa.frame_id
			AND f.deleted_at IS NULL
		LEFT JOIN eb_rank_job j ON j.id = a.job
			AND j.entid = #{entid}
		WHERE a.deleted_at IS NULL
		<if test="status != null">
			AND a.status = #{status}
		</if>
		<if test="name != null and name != ''">
			AND a.name LIKE CONCAT('%', #{name}, '%')
		</if>
		GROUP BY a.id, a.name, a.avatar, a.phone, a.job
		ORDER BY MAX(fa.is_admin) DESC, MAX(fa.is_mastart) DESC, a.id ASC
	</select>

</mapper>
