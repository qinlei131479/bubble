<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bubblecloud.biz.oa.mapper.AssessAppealMapper">

	<select id="findPg" resultType="com.bubblecloud.oa.api.entity.AssessAppeal">
		SELECT t.*
		FROM eb_assess_appeal t
		<where>
			<if test="query.assessId != null">
				AND t.assess_id = #{query.assessId}
			</if>
			<if test="query.entid != null">
				AND t.entid = #{query.entid}
			</if>
			<if test="query.userId != null">
				AND t.user_id = #{query.userId}
			</if>
			<if test="query.result != null">
				AND t.result = #{query.result}
			</if>
		</where>
		ORDER BY t.id DESC
	</select>

</mapper>
