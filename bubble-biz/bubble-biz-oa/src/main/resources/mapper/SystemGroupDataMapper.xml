<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bubblecloud.biz.oa.mapper.SystemGroupDataMapper">

	<select id="findPg" resultType="com.bubblecloud.oa.api.entity.SystemGroupData">
		SELECT t.*
		FROM eb_system_group_data t
		<where>
			<if test="query.groupId != null">
				AND t.group_id = #{query.groupId}
			</if>
			<if test="query.status != null">
				AND t.status = #{query.status}
			</if>
		</where>
		ORDER BY t.sort DESC, t.id DESC
	</select>

</mapper>
