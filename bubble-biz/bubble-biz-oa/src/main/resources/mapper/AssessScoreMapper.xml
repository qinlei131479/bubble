<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bubblecloud.biz.oa.mapper.AssessScoreMapper">

	<select id="selectMaxScoreByEntid" resultType="java.lang.Integer">
		SELECT COALESCE(MAX(`max`), 0)
		FROM eb_assess_score
		WHERE entid = #{entid}
	</select>

</mapper>
