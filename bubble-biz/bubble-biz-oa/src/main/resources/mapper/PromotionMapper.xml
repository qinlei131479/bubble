<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bubblecloud.biz.oa.mapper.PromotionMapper">

	<select id="findPg" resultType="com.bubblecloud.oa.api.entity.Promotion">
		SELECT t.*
		FROM eb_promotion t
		WHERE t.deleted_at IS NULL
	</select>

</mapper>
