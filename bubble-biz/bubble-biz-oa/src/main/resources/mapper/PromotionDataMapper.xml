<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bubblecloud.biz.oa.mapper.PromotionDataMapper">

	<select id="findPg" resultType="com.bubblecloud.oa.api.entity.PromotionData">
		SELECT t.*
		FROM eb_promotion_data t
		<where>
			AND t.deleted_at IS NULL
			<if test="query.pid != null">
				AND t.pid = #{query.pid}
			</if>
			<if test="query.entid != null">
				AND t.entid = #{query.entid}
			</if>
		</where>
		ORDER BY t.sort ASC, t.id ASC
	</select>

</mapper>
