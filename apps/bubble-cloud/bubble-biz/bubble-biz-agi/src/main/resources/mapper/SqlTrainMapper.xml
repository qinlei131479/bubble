<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.bubblecloud.biz.agi.mapper.SqlTrainMapper">

  <resultMap id="sqlTrainMap" type="com.bubblecloud.agi.api.entity.SqlTrain">
        <id property="id" column="id"/>
        <result property="dsId" column="ds_id"/>
        <result property="question" column="question"/>
        <result property="description" column="description"/>
        <result property="embedding" column="embedding" jdbcType="OTHER" typeHandler="com.bubblecloud.common.mybatis.handler.PgVectorTypeHandler"/>
        <result property="enabledFlag" column="enabled_flag"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
  </resultMap>
  
  <select id="findPg" resultType="com.bubblecloud.agi.api.entity.SqlTrain">
     SELECT t.*, ds.name AS ds_name
     FROM sql_train t
     LEFT JOIN datasource ds ON ds.id = t.ds_id
	 <where>
		 <if test="query.dsId != null">
			 AND t.ds_id = #{query.dsId}
		 </if>
		 <if test="query.enabledFlag != null ">
			 AND t.enabled_flag = #{query.enabledFlag}
		 </if>
	 </where>

  </select>
	
</mapper>