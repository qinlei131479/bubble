<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bubblecloud.biz.oa.mapper.MessageMapper">

	<select id="findPg" resultType="com.bubblecloud.oa.api.entity.Message">
		SELECT t.*
		FROM eb_message t
		<where>
			AND t.entid = #{query.entid}
			<if test="query.cateId != null and query.cateId &gt; 0">
				AND t.cate_id = #{query.cateId}
			</if>
			<if test="query.title != null and query.title != ''">
				AND t.title LIKE CONCAT('%', #{query.title}, '%')
			</if>
		</where>
		ORDER BY t.id DESC
	</select>

</mapper>
