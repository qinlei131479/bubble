<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bubblecloud.biz.oa.mapper.RankJobMapper">

	<select id="findPg" resultType="com.bubblecloud.oa.api.entity.RankJob">
		SELECT t.*
		FROM eb_rank_job t
		<where>
			<if test="query.entid != null">
				AND t.entid = #{query.entid}
			</if>
			<if test="query.status != null">
				AND t.status = #{query.status}
			</if>
		</where>
		ORDER BY t.id DESC
	</select>

</mapper>
