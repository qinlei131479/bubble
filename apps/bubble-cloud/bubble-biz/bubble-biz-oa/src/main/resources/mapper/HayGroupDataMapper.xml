<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bubblecloud.biz.oa.mapper.HayGroupDataMapper">

	<select id="findPg" resultType="com.bubblecloud.oa.api.entity.HayGroupData">
		SELECT t.*
		FROM eb_hay_group_data t
		<where>
			<if test="query.groupId != null">
				AND t.group_id = #{query.groupId}
			</if>
			<if test="query.entid != null">
				AND t.entid = #{query.entid}
			</if>
			<if test="query.userId != null">
				AND t.user_id = #{query.userId}
			</if>
		</where>
		ORDER BY t.id DESC
	</select>

</mapper>
